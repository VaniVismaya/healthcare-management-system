# ============================================
# HEALTHCARE MANAGEMENT SYSTEM - SERVER ENV
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development
APP_NAME=MediCare Pro
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3001

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=med_appoint

# JWT Configuration
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret
JWT_REFRESH_EXPIRE=30d

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=your_email@example.com

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Admin Default Credentials
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@medicare.com
ADMIN_PASSWORD=change_this_default_password
ADMIN_PHONE=+919999999999

# Encryption
ENCRYPTION_KEY=replace_with_32_character_secret_key

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# OTP Configuration
OTP_EXPIRE_MINUTES=10

# Firebase Admin (choose one approach)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Zoom Configuration
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_USER_ID=your_zoom_user_email
APP_TIMEZONE=Asia/Kolkata

# Subscription Plans
PLAN_FREE_APPOINTMENTS=10
PLAN_BASIC_PRICE=999
PLAN_PREMIUM_PRICE=2999
PLAN_ENTERPRISE_PRICE=9999

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Paytm Configuration
PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=WEBSTAGING
PAYTM_ENV=staging
PAYTM_CALLBACK_URL=http://localhost:5000/api/payments/paytm/callback

# Razorpay Configuration
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CALLBACK_URL=http://localhost:3001/patient/book

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3001/patient/book?stripe_order={ORDER_ID}
STRIPE_CANCEL_URL=http://localhost:3001/patient/book
